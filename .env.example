# ── Brain service ──────────────────────────────────────────────────────────
# Shared secret. Every caller must send: Authorization: Bearer <BRAIN_API_KEY>
BRAIN_API_KEY=change-me

# ── Ollama Cloud (LLM only — Brain owns this key) ──────────────────────────
OLLAMA_API_KEY=
OLLAMA_BASE_URL=https://ollama.com
# Verify this id exists on your cloud account: `python scripts/check_ollama.py`
CHAT_MODEL=gpt-oss:120b

# ── Qdrant Cloud (vector store) ────────────────────────────────────────────
QDRANT_URL=
QDRANT_API_KEY=
# One collection per app: the collection name is derived from each request's
# `app_name` (e.g. app_name="portfolio" → collection "portfolio"). Set a prefix
# here to namespace them all (e.g. "brain_" → "brain_portfolio"). Leave blank
# to use the app_name verbatim.
QDRANT_COLLECTION_PREFIX=

# ── Embeddings + reranking (local fastembed, downloaded once) ──────────────
EMBED_MODEL=BAAI/bge-base-en-v1.5
RERANK_MODEL=Xenova/ms-marco-MiniLM-L-6-v2

# ── Retrieval / chunking knobs ─────────────────────────────────────────────
RETRIEVE_TOP_K=25
RERANK_TOP_N=5
CHUNK_MAX_TOKENS=320
CHUNK_MIN_TOKENS=80
SEMANTIC_THRESHOLD=0.5
